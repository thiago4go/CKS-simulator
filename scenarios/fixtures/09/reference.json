{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {"name": "apparmor", "namespace": "default"},
  "spec": {
    "replicas": 1,
    "selector": {"matchLabels": {"app": "apparmor"}},
    "template": {
      "metadata": {"labels": {"app": "apparmor"}},
      "spec": {
        "nodeSelector": {"security": "apparmor"},
        "containers": [{
          "name": "c1",
          "image": "nginx@sha256:54f2a904c251d5a34adf545a72d32515a15e08418dae0266e23be2e18c66fefa",
          "securityContext": {"appArmorProfile": {"type": "Localhost", "localhostProfile": "k8s-apparmor-deny-write"}}
        }]
      }
    }
  }
}
