{
  "apiVersion": "v1",
  "kind": "List",
  "items": [
    {"apiVersion": "v1", "kind": "Namespace", "metadata": {"name": "team-pink"}},
    {"apiVersion": "v1", "kind": "Secret", "metadata": {"name": "secure-tls", "namespace": "team-pink"}, "type": "Opaque", "stringData": {"tls.key": "provided-tls-key", "tls.crt": "provided-tls-cert"}},
    {"apiVersion": "v1", "kind": "Service", "metadata": {"name": "app", "namespace": "team-pink"}, "spec": {"selector": {"app": "app"}, "ports": [{"port": 80}]}},
    {"apiVersion": "networking.k8s.io/v1", "kind": "Ingress", "metadata": {"name": "secure", "namespace": "team-pink"}, "spec": {"rules": [{"host": "secure-ingress.test", "http": {"paths": [{"path": "/app", "pathType": "Prefix", "backend": {"service": {"name": "app", "port": {"number": 80}}}}, {"path": "/api", "pathType": "Prefix", "backend": {"service": {"name": "app", "port": {"number": 80}}}}]}}]}}
  ]
}
